# Signal Client 設定（含券商憑證，放在用戶自己機器上）
signal_client:
  server_url: "http://your-server:8000"
  token: "your-token-here"
  poll_interval_sec: 1800        # 每 30 分鐘拉一次訊號

broker:
  api_key: ""                    # 從環境變數 SHIOAJI_API_KEY 讀取
  secret_key: ""                 # 從環境變數 SHIOAJI_SECRET_KEY 讀取
  simulation: true               # 上線前先用 simulation

portfolio:
  max_positions: 5
  position_size_pct: 0.30

risk:
  stop_loss_pct: 0.06
  take_profit_pct: 0.12
  position_size_pct: 0.30

notification:
  enabled: false
  telegram:
    bot_token: ""
    chat_id: ""
