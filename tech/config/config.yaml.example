# 複製此檔為 config.yaml 並填入設定

broker:
  api_key: ""
  secret_key: ""
  ca_path: ""
  ca_passwd: ""
  person_id: ""
  simulation: true

# ── 大盤過濾 ──────────────────────────────────────────────────────────────
# 只在大盤（0050）站上 MA 時才開倉，避免在空頭市場逆勢買進。
# 回測比較結果（2025-04-01 起，30 檔，停利 25%）：
#   MA20 → 實際報酬 +0.19%   MA10 → 實際報酬 +10.08%
# MA10 反應更快，V 型反彈時可更早進場；缺點是空頭初期可能多幾筆假訊號。
market_filter:
  enabled: true
  proxy_code: "0050"
  ma_period: 20        # 建議 20（穩）；牛市偏好 10（快）
  bull_entry_only: false  # true=只有牛市（MA20>MA60）才允許進場（更嚴格）
  breadth_min: 0.50    # 市場廣度下限：候選股站上EMA20比例需>=此值（0=停用）
  breadth_max: 0.82    # 市場廣度上限：比例超過此值視為過熱暫停（0=停用）
  max_20d_gain: 0.10   # 0050近20日漲幅超過10%視為過熱，暫停開倉（0=停用）
  max_10d_gain: 0.07   # 0050近10日漲幅超過7%視為過熱（0=停用）
  max_atr_pct: 0.015   # 0050 ATR%超過1.5%視為震盪過激，暫停開倉（0=停用）
  vix_panic_threshold: 0   # VIX >= 此值允許 panic_rebound 繞過偏空封鎖（0=停用；建議30）
  vix_park_hi: 30      # VIXTWN >= 此值時閒置資金停泊 00631L（0=停用）
  vix_park_lo: 20      # VIXTWN <= 此值時切回停泊 0050

# ── 風控 ──────────────────────────────────────────────────────────────────
risk:
  max_positions: 4           # 同時最多持幾檔，超過則等待既有部位出場再進新倉
  bull_max_positions: 0      # 牛市（0050 MA20>MA60）時放寬至此數；0=不放寬
  max_position_pct: 0.25     # 單檔最多佔總資金比例
  stop_loss_pct: 0.08        # 固定停損比例；stop_atr_mult > 0 時改用 ATR 動態停損
  stop_atr_mult: 3.5         # ATR 動態停損倍數（0=停用，使用固定 stop_loss_pct）
  take_profit_pct: 0.25
  max_daily_loss_pct: 0.03
  min_order_value: 10000
  max_order_value: 500000
  consecutive_loss_pause:
    count: 3
    pause_minutes: 60
  trailing_stop:
    activation_pct: 0.02     # 獲利達 2% 後啟動移動停損
    trail_pct: 0.15          # 從最高點回落 15% 出場
    trail_stop_bull_pct: 0.20  # 牛市（MA20>MA60）時改用此值（0=不區分）
    trail_stop_rs_bonus: 0.05  # RS強勢個股（RS>0.1）額外放寬（0=停用）
  time_stop_days: 20         # 持倉超過N天且漲幅未達門檻強制出場（0=停用）
  time_stop_min_pct: 0.05    # 時間停損最低漲幅門檻
  max_sell_retries: 5
  loss_cooldown_days: 5      # 停損出場後冷卻天數（0=停用）
  # 大盤深度回撤縮倉
  market_dd_threshold: 0.10  # 0050 從高點回撤 >= 此值時縮倉（0=停用）
  market_dd_max_positions: 2 # 大盤回撤時持倉上限
  # EMA 乖離動態倉位（0=停用）
  dev_low_thr:  0.03
  dev_high_thr: 0.05
  dev_low_pct:  0.10
  dev_high_mult: 1.4
  # RS 個股動態倉位（0=停用）
  rs_pos_high_thr:  0.15     # RS >= 此值放大倉位
  rs_pos_high_mult: 1.80     # 高 RS 倉位乘數
  rs_pos_low_thr:   0.07     # RS <= 此值縮小倉位
  rs_pos_low_mult:  0.80     # 低 RS 倉位乘數
  order_chase:
    enabled: true
    after_minutes: 5
    max_pct: 0.015
    max_retries: 1

# ── 贏家加碼 ──────────────────────────────────────────────────────────────
pyramid:
  gain_pct:  0.20   # 第一次加碼：持倉獲利達 20% 觸發（0=停用）
  gain2_pct: 0.40   # 第二次加碼：持倉獲利達 40% 觸發（0=停用）
  rs_min:    0.05   # 第二次加碼需個股近20日 RS > 此值（0=不檢查）
  alloc_pct: 0.50   # 加碼倉位比例，佔原始倉位成本

# ── 選股過濾 ──────────────────────────────────────────────────────────────
screener:
  exchanges: ["TSE", "OTC"]
  min_price: 10.0
  max_price: 2000.0
  min_volume: 1000
  min_avg_volume_5d: 2000
  max_stocks: 80
  max_evaluate: 30
  exclude_etf: true
  exclude_disposed: true
  max_avg_daily_range_pct: 0
  min_rs_entry: 0.13       # 進場最低 RS（個股20日報酬 - 0050）；0=停用
  max_rs_entry: 0.40       # 進場最高 RS（趨勢末段過濾）；0=停用

# ── 排名系統（hybrid 模式對齊回測）────────────────────────────────────────────
rank:
  w_conf:     0.00    # 信心值權重（多策略共識加成）
  w_rs:       0.41    # RS 強度權重（個股相對 0050 強度，最重要）
  w_dev:      0.20    # EMA20 乖離率權重（進場位置質量）
  w_rs_sweet: 0.19    # RS 甜蜜點加分（RS 在甜蜜點附近最高分）
  w_chip:     0.25    # 籌碼評分權重（short_util 低 + 外資買 → 高分）
  w_breadth:  0.00    # 市場廣度權重（live 端固定 0.5，建議留 0）
  rs_center:      0.12  # RS 線性分的起算點（低於此分較少加分）
  rs_span:        0.25  # RS 線性分的跨度
  rs_sweet_spot:  0.20  # RS 甜蜜點中心值
  rs_sweet_tol:   0.10  # RS 甜蜜點容差（±此值內滿分）
  dev_sweet_spot: 0.05  # EMA乖離甜蜜點（5% 最佳）
  dev_tol:        0.03  # EMA乖離容差
  min_rank_score: 0.38  # 進場最低排名分數門檻；低於此分跳過（0=停用）

# ── 籌碼過濾 ──────────────────────────────────────────────────────────────────
chip_filter:
  enabled: true
  margin_short_ratio_max: 4.0   # 資券比超過此值跳過（0=停用）
  short_util_max: 0.08          # 融券使用率超過此值跳過（0=停用）

# ── 進場過濾 ────────────────────────────────────────────────────────────────
# 開盤跳空過濾：開盤價 vs 昨收漲幅超過閾值視為「噴出」，延遲進場。
# gap_up_threshold: 0 可完全關閉此功能。
entry_filter:
  gap_up_threshold: 0.03    # 開盤跳空 > 3% 視為噴出（0 = 停用）
  gap_up_delay_time: "09:30" # 噴出時等到此時間後才重新評估
  gap_up_volume_ratio: 0.8   # 噴出後需當天累積量 > 20日均量 × 此比例才進場

# ── 策略 ──────────────────────────────────────────────────────────────────
# 多策略同時觸發同一檔股票時，信心值會疊加（consensus boosting）。
# 建議至少保留 ema_trend + kd_cross，這兩組在回測中訊號最多、表現最穩。
strategies:
  active: ["momentum", "breakout", "mean_reversion", "ema_trend", "kd_cross"]
  # panic_rebound 預設不啟用；搭配 vix_panic_threshold 使用
  # active: ["ema_trend", "kd_cross", "panic_rebound"]

  # 動能策略：RSI 脫離超賣 + MACD 柱狀翻正
  momentum:
    rsi_period: 14
    rsi_oversold: 35
    rsi_overbought: 65
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    lookback_days: 30

  # 均值回歸：價格碰布林下軌 + RSI < 30（超跌反彈）
  mean_reversion:
    bb_period: 20
    bb_std: 2.0
    rsi_period: 14
    rsi_low: 30
    rsi_high: 70
    lookback_days: 30

  # 突破策略：收盤突破 20 日高點 + 爆量（量確認方向）
  breakout:
    volume_multiplier: 2.0
    price_breakout_pct: 0.02
    lookback_days: 20
    confirm_days: 3

  # EMA 多頭排列：EMA5 > EMA20 > EMA60 且量能配合（趨勢跟隨）
  ema_trend:
    ema_fast: 5
    ema_mid: 20
    ema_slow: 60
    vol_confirm: true
    lookback_days: 70
    adx_period: 14         # ADX 計算週期
    adx_min: 20            # ADX 低於此值視為橫盤，不進場（0 = 停用）
    max_ema_dev: 0.08      # 收盤距 EMA20 乖離率上限，超過視為追高不進場（0 = 停用）
    min_atr_pct: 2.0       # ATR% 下限，低於此值視為死魚股不進場（0 = 停用）

  # 恐慌反彈策略：RSI < 25 + 跌破布林下軌 + 爆量（恐慌賣盤宣洩）
  # 搭配 market_filter.vix_panic_threshold 使用，VIX 高時才實際進場
  panic_rebound:
    rsi_period: 14
    rsi_threshold: 25    # 比 mean_reversion 更深的超賣（建議 22~28）
    bb_period: 20
    bb_std: 2.0
    vol_spike: 1.5       # 當日量 >= 5日均量 × 此倍數才進場（恐慌爆量確認）
    lookback_days: 30

  # KD 黃金交叉：K 從超賣區上穿 D + RSI 回升（短線反彈）
  kd_cross:
    kd_period: 9
    k_oversold: 25
    rsi_period: 14
    lookback_days: 30

# ── 排程 ──────────────────────────────────────────────────────────────────
schedule:
  market_open: "09:00"
  market_close: "13:30"
  ignore_trading_hours: false  # true=忽略 09:00~13:30 限制，任何時間都可跑
  scan_interval_minutes: 30
  rebalance_time: "09:15"
  heartbeat_interval_minutes: 30  # 心跳通知間隔（分鐘）
  fast_exit_interval_minutes: 2   # 快速出場監控間隔（分鐘）
  force_close_minutes_before_close: 0  # 0=停用；設為 10 表示 13:20 強制平倉所有持倉（防隔夜風險）
  # holidays: ["2025-09-01"]  # 可追加颱風假等，格式 YYYY-MM-DD

# ── 日誌 ──────────────────────────────────────────────────────────────────
logging:
  level: "INFO"
  file: "tech/logs/trading.log"
  max_bytes: 10485760  # 10 MB
  backup_count: 5

# ── 通知 ──────────────────────────────────────────────────────────────────
notifications:
  enabled: false
  line_token: ""      # LINE Notify Token，或設環境變數 LINE_NOTIFY_TOKEN
  telegram:
    bot_token: ""     # Telegram Bot Token，或設環境變數 TELEGRAM_BOT_TOKEN
    chat_id: ""       # Telegram Chat ID，或設環境變數 TELEGRAM_CHAT_ID
