# 複製此檔為 config.yaml 並填入設定

broker:
  api_key: ""
  secret_key: ""
  ca_path: ""
  ca_passwd: ""
  person_id: ""
  simulation: true

market_filter:
  enabled: true
  proxy_code: "0050"
  ma_period: 20

risk:
  max_positions: 5
  max_position_pct: 0.20
  stop_loss_pct: 0.05
  take_profit_pct: 0.15
  max_daily_loss_pct: 0.03
  min_order_value: 10000
  max_order_value: 500000
  consecutive_loss_pause:
    count: 3           # 連續虧損幾次後暫停開倉
    pause_minutes: 60  # 暫停時間（分鐘）
  trailing_stop:
    activation_pct: 0.07   # 獲利達 7% 後啟動移動停損
    trail_pct: 0.04         # 從最高點回落 4% 出場
  max_sell_retries: 5      # 賣出失敗達此次數後停止自動重試，需人工確認
  loss_cooldown_days: 5    # 個股停損出場後冷卻天數，期間不再進場；0 = 停用
  order_chase:
    enabled: true          # 掛單未成交時自動追單
    after_minutes: 5       # 掛出幾分鐘後仍 Active 才追
    max_pct: 0.015         # 最高追至原始下單價 + 1.5%，超過則放棄
    max_retries: 1         # 最多追幾次

screener:
  exchanges: ["TSE", "OTC"]
  min_price: 10.0
  max_price: 1000.0
  min_volume: 1000
  min_avg_volume_5d: 2000
  max_stocks: 50
  max_evaluate: 30   # 策略評估最多跑幾檔（依成交量排序）
  exclude_etf: true       # 排除 ETF（代碼 00 開頭），避免除息/分割干擾技術訊號
  exclude_disposed: true  # 排除處置股（day_trade=No），撮合受限掛單難成交
  max_avg_daily_range_pct: 6.0  # 排除日均振幅 > 此值(%)的高波動股；0 = 停用

strategies:
  # 可任意組合，多策略同時觸發時信心值加成
  active: ["momentum", "breakout", "mean_reversion", "ema_trend", "kd_cross"]

  momentum:
    rsi_period: 14
    rsi_oversold: 35
    rsi_overbought: 65
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    lookback_days: 30

  mean_reversion:
    bb_period: 20
    bb_std: 2.0
    rsi_period: 14
    rsi_low: 30
    rsi_high: 70
    lookback_days: 30

  breakout:
    volume_multiplier: 2.0
    price_breakout_pct: 0.02
    lookback_days: 20
    confirm_days: 3

  ema_trend:
    ema_fast: 5
    ema_mid: 20
    ema_slow: 60
    vol_confirm: true
    lookback_days: 70

  kd_cross:
    kd_period: 9
    k_oversold: 25
    rsi_period: 14
    lookback_days: 30

schedule:
  market_open: "09:00"
  market_close: "13:30"
  ignore_trading_hours: false  # true=忽略 09:00~13:30 限制，任何時間都可跑
  scan_interval_minutes: 30
  rebalance_time: "09:15"
  heartbeat_interval_minutes: 30  # 心跳通知間隔（分鐘）
  fast_exit_interval_minutes: 2   # 快速出場監控間隔（分鐘）
  force_close_minutes_before_close: 0  # 0=停用；設為 10 表示 13:20 強制平倉所有持倉（防隔夜風險）
  # holidays: ["2025-09-01"]  # 可追加颱風假等，格式 YYYY-MM-DD

logging:
  level: "INFO"
  file: "tech/logs/trading.log"
  max_bytes: 10485760
  backup_count: 5

notifications:
  enabled: false
  line_token: ""      # LINE Notify Token，或設環境變數 LINE_NOTIFY_TOKEN
  telegram:
    bot_token: ""     # Telegram Bot Token，或設環境變數 TELEGRAM_BOT_TOKEN
    chat_id: ""       # Telegram Chat ID，或設環境變數 TELEGRAM_CHAT_ID
