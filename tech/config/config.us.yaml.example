# 美股策略設定（Alpaca Paper/Live Trading）
# 複製此檔為 config.us.yaml 並填入設定
# 啟動：python tech/main.py --config tech/config/config.us.yaml

broker:
  api_key: ""      # Alpaca API Key ID（或設環境變數 ALPACA_API_KEY）
  secret_key: ""   # Alpaca Secret Key（或設環境變數 ALPACA_SECRET_KEY）
  simulation: true  # true=paper trading，false=live trading

# ── 大盤過濾 ──────────────────────────────────────────────────────────────
market_filter:
  enabled: true
  proxy_code: "SPY"
  ma_period: 20
  breadth_min: 0.50
  max_20d_gain: 0.10
  max_10d_gain: 0.07
  max_atr_pct: 0.015
  vix_panic_threshold: 0   # VIX >= 此值允許 panic_rebound 進場（建議 30；0=停用）

# ── 風控 ──────────────────────────────────────────────────────────────────
risk:
  max_positions: 5
  bull_max_positions: 0
  max_position_pct: 0.20
  stop_loss_pct: 0.05
  take_profit_pct: 0.25
  max_daily_loss_pct: 0.03
  min_order_value: 100      # USD
  max_order_value: 50000    # USD
  consecutive_loss_pause:
    count: 3
    pause_minutes: 60
  trailing_stop:
    activation_pct: 0.10
    trail_pct: 0.05
    trail_stop_bull_pct: 0.18
    trail_stop_rs_bonus: 0.05
  time_stop_days: 20
  time_stop_min_pct: 0.05
  max_sell_retries: 5
  loss_cooldown_days: 5
  dev_low_thr:  0.03
  dev_high_thr: 0.05
  dev_low_pct:  0.15
  dev_high_mult: 1.4
  order_chase:
    enabled: true
    after_minutes: 5
    max_pct: 0.015
    max_retries: 1

# ── 贏家加碼 ──────────────────────────────────────────────────────────────
pyramid:
  gain_pct:  0.20
  gain2_pct: 0.40
  rs_min:    0.05
  alloc_pct: 0.50

# ── 選股過濾 ──────────────────────────────────────────────────────────────
screener:
  exchanges: ["NASDAQ", "NYSE"]
  min_price: 10.0
  max_price: 5000.0
  min_volume: 500000        # 美股量級不同，最低50萬股
  min_avg_volume_5d: 1000000
  max_stocks: 50
  max_evaluate: 30
  exclude_etf: false        # 美股 ETF 代碼無固定規則，由 screener 自行判斷
  exclude_disposed: false   # 美股無處置制度

# ── 進場過濾 ──────────────────────────────────────────────────────────────
entry_filter:
  gap_up_threshold: 0.03
  gap_up_delay_time: "09:45"
  gap_up_volume_ratio: 0.8

# ── 策略 ──────────────────────────────────────────────────────────────────
strategies:
  active: ["ema_trend", "kd_cross"]

  momentum:
    rsi_period: 14
    rsi_oversold: 35
    rsi_overbought: 65
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    lookback_days: 30

  mean_reversion:
    bb_period: 20
    bb_std: 2.0
    rsi_period: 14
    rsi_low: 30
    rsi_high: 70
    lookback_days: 30

  breakout:
    volume_multiplier: 2.0
    price_breakout_pct: 0.02
    lookback_days: 20
    confirm_days: 3

  ema_trend:
    ema_fast: 5
    ema_mid: 20
    ema_slow: 60
    vol_confirm: true
    lookback_days: 70
    adx_period: 14
    adx_min: 20
    max_ema_dev: 0.08
    min_atr_pct: 2.0

  kd_cross:
    kd_period: 9
    k_oversold: 25
    rsi_period: 14
    lookback_days: 30

  panic_rebound:
    rsi_period: 14
    rsi_threshold: 25
    bb_period: 20
    bb_std: 2.0
    vol_spike: 1.5
    lookback_days: 30

# ── 排程 ──────────────────────────────────────────────────────────────────
schedule:
  market_open: "09:30"      # NYSE 開盤（ET，需依本地時區調整）
  market_close: "16:00"
  ignore_trading_hours: false
  scan_interval_minutes: 30
  rebalance_time: "09:45"
  heartbeat_interval_minutes: 30
  fast_exit_interval_minutes: 2
  force_close_minutes_before_close: 0

# ── 日誌 ──────────────────────────────────────────────────────────────────
logging:
  level: "INFO"
  file: "tech/logs/trading.log"
  max_bytes: 10485760
  backup_count: 5

# ── 通知 ──────────────────────────────────────────────────────────────────
notifications:
  enabled: false
  line_token: ""
  telegram:
    bot_token: ""
    chat_id: ""
