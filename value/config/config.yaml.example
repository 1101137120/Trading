# 複製此檔為 config.yaml 並填入設定

broker:
  api_key: ""
  secret_key: ""
  ca_path: ""
  ca_passwd: ""
  person_id: ""
  simulation: true

risk:
  max_positions: 5
  max_position_pct: 0.20
  stop_loss_pct: 0.08
  take_profit_pct: 0.25
  max_daily_loss_pct: 0.03
  min_order_value: 10000
  max_order_value: 500000
  consecutive_loss_pause:
    count: 3           # 連續虧損幾次後暫停開倉
    pause_minutes: 60  # 暫停時間（分鐘）

value_screener:
  max_pe: 20
  min_dividend_yield: 0.02
  max_pb: 4.0
  min_price: 10.0
  max_price: 500.0
  max_stocks: 20

tech_screener:
  enabled: true
  max_pe: 35
  min_dividend_yield: 0
  max_pb: 6.0
  min_price: 20.0
  max_price: 1000.0
  max_stocks: 15

market_filter:
  enabled: true
  proxy_code: "0050"
  ma_period: 20

strategies:
  active: ["momentum", "breakout"]

  momentum:
    rsi_period: 14
    rsi_oversold: 35
    rsi_overbought: 65
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    lookback_days: 30

  mean_reversion:
    bb_period: 20
    bb_std: 2.0
    rsi_period: 14
    rsi_low: 30
    rsi_high: 70
    lookback_days: 30

  breakout:
    volume_multiplier: 2.0
    price_breakout_pct: 0.02
    lookback_days: 20
    confirm_days: 3

schedule:
  market_open: "09:00"
  market_close: "13:30"
  scan_interval_minutes: 30
  heartbeat_interval_minutes: 30  # 心跳通知間隔（分鐘）
  # holidays: ["2025-09-01"]  # 可追加颱風假等，格式 YYYY-MM-DD

logging:
  level: "INFO"
  file: "value/logs/trading.log"
  max_bytes: 10485760
  backup_count: 5

notifications:
  enabled: false
  line_token: ""      # LINE Notify Token，或設環境變數 LINE_NOTIFY_TOKEN
  telegram:
    bot_token: ""     # Telegram Bot Token，或設環境變數 TELEGRAM_BOT_TOKEN
    chat_id: ""       # Telegram Chat ID，或設環境變數 TELEGRAM_CHAT_ID
