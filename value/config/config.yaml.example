# 複製此檔為 config.yaml 並填入設定

broker:
  api_key: ""
  secret_key: ""
  ca_path: ""
  ca_passwd: ""
  person_id: ""
  simulation: true

risk:
  max_positions: 5
  max_position_pct: 0.20
  stop_loss_pct: 0.08
  take_profit_pct: 0.25
  max_daily_loss_pct: 0.03
  min_order_value: 10000
  max_order_value: 500000
  consecutive_loss_pause:
    count: 3           # 連續虧損幾次後暫停開倉
    pause_minutes: 60  # 暫停時間（分鐘）
  trailing_stop:
    activation_pct: 0.10   # 獲利達 10% 後啟動移動停損
    trail_pct: 0.05         # 從最高點回落 5% 出場
  max_sell_retries: 5      # 賣出失敗達此次數後停止自動重試，需人工確認

value_screener:
  max_pe: 20
  min_dividend_yield: 0.02
  max_pb: 4.0
  min_price: 10.0
  max_price: 500.0
  max_stocks: 20

tech_screener:
  enabled: true
  max_pe: 35
  min_dividend_yield: 0
  max_pb: 6.0
  min_price: 20.0
  max_price: 1000.0
  max_stocks: 15

relative_strength:
  lookbacks: [20, 60, 120]     # 多週期報酬率
  weights: [0.5, 0.3, 0.2]     # 對應週期權重（會自動正規化）
  volatility_penalty: 0.20     # 近20日波動懲罰係數（0=不懲罰）
  market_code: "0050"          # 大盤代理
  fs_weight: 0.4               # 基本面分在綜合排序的權重
  rs_weight: 0.6               # RS分在綜合排序的權重（偏品質+動能）

quality_factors:
  enabled: true
  source: "yfinance"
  real_quality_weight: 0.7
  max_calls_per_run: 40
  sleep_seconds: 0.05
  weights:
    roe: 14
    eps_growth: 10
    revenue_growth: 10
    debt_to_equity: 6

v2_gate:
  enabled: true
  hard_filters:
    min_fs_total: 55.0
    require_pe_positive: true
    pe_min: 6.0
    pe_max: 120.0
    pb_max: 5.0
    yield_min_pct: 0.0
    yield_max_pct: 12.0
    min_price: 10.0
    max_price: 2000.0
    min_roe_pct: null
    min_eps_growth_pct: null
    min_revenue_growth_pct: null
    max_debt_to_equity: null
    require_real_quality_metrics: false
  rs:
    require_positive: true
    min_rs_score: 0.0
  diversification:
    max_per_type:
      value: 10
      tech: 15
    max_same_prefix2: 4

market_filter:
  enabled: true
  proxy_code: "0050"
  ma_period: 20

strategies:
  active: ["momentum", "breakout"]

  momentum:
    rsi_period: 14
    rsi_oversold: 35
    rsi_overbought: 65
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    lookback_days: 30

  mean_reversion:
    bb_period: 20
    bb_std: 2.0
    rsi_period: 14
    rsi_low: 30
    rsi_high: 70
    lookback_days: 30

  breakout:
    volume_multiplier: 2.0
    price_breakout_pct: 0.02
    lookback_days: 20
    confirm_days: 3

schedule:
  market_open: "09:00"
  market_close: "13:30"
  scan_interval_minutes: 30
  heartbeat_interval_minutes: 30  # 心跳通知間隔（分鐘）
  fast_exit_interval_minutes: 2   # 快速出場監控間隔（分鐘）
  force_close_minutes_before_close: 0  # 0=停用；設為 10 表示 13:20 強制平倉所有持倉（防隔夜風險）
  # holidays: ["2025-09-01"]  # 可追加颱風假等，格式 YYYY-MM-DD

logging:
  level: "INFO"
  file: "value/logs/trading.log"
  max_bytes: 10485760
  backup_count: 5

notifications:
  enabled: false
  line_token: ""      # LINE Notify Token，或設環境變數 LINE_NOTIFY_TOKEN
  telegram:
    bot_token: ""     # Telegram Bot Token，或設環境變數 TELEGRAM_BOT_TOKEN
    chat_id: ""       # Telegram Chat ID，或設環境變數 TELEGRAM_CHAT_ID
