# ── 敏感設定（含 API Key / CA 密碼，絕不 commit）──────────────────────────
tech/config/config.yaml
value/config/config.yaml

# ── 憑證與私鑰 ──────────────────────────────────────────────────────────────
*.pfx
*.pem
*.p12
*.key

# ── 環境變數檔 ──────────────────────────────────────────────────────────────
.env
.env.*

# ── 執行期資料（持倉、心跳，含帳務資訊）──────────────────────────────────
tech/data/
value/data/

# ── 日誌（含成交紀錄、帳號資訊）─────────────────────────────────────────
tech/logs/
value/logs/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/

# ── 系統 ────────────────────────────────────────────────────────────────────
.DS_Store

# ── 其他執行期產生的檔案 ─────────────────────────────────────────────────
shioaji.log
*.log
.claude/

# ── 資料庫（本地快照，體積大且可重建）───────────────────────────────────
data/*.db
